# 모바일 WebView가 로드할 웹 앱 URL (운영은 HTTPS 필수)
# 권장 키(비-Expo 지향): MOBILE_WEB_APP_URL
MOBILE_WEB_APP_URL=https://your-domain.com/today

# 허용 도메인 allowlist (쉼표 구분)
# 예: your-domain.com,www.your-domain.com
MOBILE_WEB_APP_ALLOWED_HOSTS=your-domain.com

# 레거시 호환(기존 Expo 키) - 필요 시만 사용
# EXPO_PUBLIC_WEB_APP_URL=https://your-domain.com/today
# EXPO_PUBLIC_WEB_APP_ALLOWED_HOSTS=your-domain.com
