# 모바일 WebView가 로드할 웹 앱 URL (운영은 HTTPS 필수)
MOBILE_WEB_APP_URL=https://routine-pages.pages.dev/today
EXPO_PUBLIC_WEB_APP_URL=https://routine-pages.pages.dev/today

# 허용 도메인 allowlist (쉼표 구분)
MOBILE_WEB_APP_ALLOWED_HOSTS=routine-pages.pages.dev
EXPO_PUBLIC_WEB_APP_ALLOWED_HOSTS=routine-pages.pages.dev
